"use client";

import { BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, Legend, ResponsiveContainer } from 'recharts';

// เนื่องจาก Recharts เป็น Client-side library, เราจึงต้องสร้าง Client Component แยกออกมา
// รับ props (results) จาก Server Component

type ExamResult = {
    id: string;
    score: number;
    totalQuestions: number;
    completedAt: Date;
    exam: {
        title: string;
    };
};

interface DashboardClientProps {
    results: ExamResult[];
}

export default function DashboardClient({ results }: DashboardClientProps) {
    // แปลงข้อมูลเพื่อให้เหมาะกับกราฟ
    const chartData = results.map(r => ({
        name: new Date(r.completedAt).toLocaleDateString('th-TH'),
        score: (r.score / r.totalQuestions) * 100, // แสดงเป็นเปอร์เซ็นต์
        title: r.exam.title
    })).reverse(); // เรียงจากเก่าไปใหม่

    return (
        <div className="space-y-8">
            <div className="bg-white p-6 rounded-lg shadow">
                <h2 className="text-xl font-semibold mb-4">ภาพรวมคะแนนล่าสุด (ร้อยละ)</h2>
                {results.length > 0 ? (
                    <ResponsiveContainer width="100%" height={300}>
                        <BarChart data={chartData}>
                            <CartesianGrid strokeDasharray="3 3" />
                            <XAxis dataKey="name" />
                            <YAxis domain={[0, 100]} />
                            <Tooltip formatter={(value) => `${Number(value).toFixed(2)}%`} />
                            <Legend />
                            <Bar dataKey="score" fill="#8884d8" name="คะแนน" />
                        </BarChart>
                    </ResponsiveContainer>
                ) : (
                    <p className="text-gray-500">ยังไม่มีข้อมูลการทำข้อสอบ</p>
                )}
            </div>

            <div className="bg-white p-6 rounded-lg shadow">
                <h2 className="text-xl font-semibold mb-4">ประวัติการทำข้อสอบ</h2>
                <div className="overflow-x-auto">
                    <table className="min-w-full divide-y divide-gray-200">
                        <thead className="bg-gray-50">
                            <tr>
                                <th scope="col" className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ชื่อชุดข้อสอบ</th>
                                <th scope="col" className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">คะแนน</th>
                                <th scope="col" className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">วันที่ทำ</th>
                            </tr>
                        </thead>
                        <tbody className="bg-white divide-y divide-gray-200">
                            {results.map((result) => (
                                <tr key={result.id}>
                                    <td className="px-6 py-4 whitespace-nowrap">{result.exam.title}</td>
                                    <td className="px-6 py-4 whitespace-nowrap">{result.score} / {result.totalQuestions}</td>
                                    <td className="px-6 py-4 whitespace-nowrap">{new Date(result.completedAt).toLocaleString('th-TH')}</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    );
}
